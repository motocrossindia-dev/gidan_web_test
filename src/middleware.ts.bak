import { NextRequest, NextResponse } from 'next/server';
import { userAgent } from 'next/server';

/**
 * Middleware for server-side mobile detection.
 * Sets a cookie `device-type` that can be read by client components.
 * This replaces the CRA pattern of `isMobile` from react-device-detect
 * for cases where you need server-side awareness.
 */
export function middleware(request: NextRequest) {
  const { device } = userAgent(request);
  const deviceType = device.type === 'mobile' ? 'mobile' : 'desktop';

  const response = NextResponse.next();

  // Set device type as a cookie so client components can read it on first render
  response.cookies.set('device-type', deviceType, {
    httpOnly: false,
    sameSite: 'lax',
    path: '/',
  });

  // Also set as a request header for server components
  response.headers.set('x-device-type', deviceType);

  return response;
}

export const config = {
  // Run on all routes except static files and API routes
  matcher: ['/((?!_next/static|_next/image|favicon.ico|.*\\.(?:svg|png|jpg|jpeg|gif|webp)$).*)'],
};
